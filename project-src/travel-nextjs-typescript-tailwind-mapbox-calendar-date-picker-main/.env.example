# Supabase public client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only key. Never import this in React/client code.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe server-only keys
STRIPE_SECRET_KEY=
STRIPE_INTERNAL_WEBHOOK_SECRET=

# Protege as rotas de cron (/api/cron/*). Gere um valor aleatório longo e
# defina TAMBÉM nas envs da Vercel — o Vercel Cron envia
# "Authorization: Bearer ${CRON_SECRET}" automaticamente.
CRON_SECRET=

# Public site URL used by server redirects/callbacks.
# Local: http://localhost:3000
# Production: https://travel-nextjs-typescript-tailwind-m.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# External APIs
MAPBOX_API_KEY=
RAPIDAPI_KEY=

# Legacy browser tokens while Mapbox external search still exists
NEXT_PUBLIC_MAPBOX_TOKEN=

# Notes:
# - RAPIDAPI_KEY is private and must not use NEXT_PUBLIC_.
# - SUPABASE_SERVICE_ROLE_KEY is private and must be used only in API Routes,
#   webhooks, server actions, or backend-only routines.
# - Variables used by browser/client code must start with NEXT_PUBLIC_.
